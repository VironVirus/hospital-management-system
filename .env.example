# Hostinger MySQL database credentials
DB_HOST=your-mysql-host
DB_PORT=3306
DB_NAME=your-database-name
DB_USER=your-database-user
DB_PASSWORD=your-strong-database-password
DB_POOL_SIZE=8

# First deployment only: creates the initial Admin when no Admin exists
HMS_ADMIN_NAME=Hospital Administrator
HMS_ADMIN_EMAIL=admin@stgiannahospital.com
HMS_ADMIN_PASSWORD=replace-with-a-long-unique-password

NODE_ENV=production
